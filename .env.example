# ============================================================
# Default model for agents
# Examples:
#   gemini-2.0-flash                     (Google, native)
#   gpt-5.2                              (OpenAI via LiteLLM proxy)
#   openai/gpt-4o                        (OpenAI via LiteLLM)
#   anthropic/claude-sonnet-4-20250514   (Anthropic via LiteLLM)
# ============================================================
DEFAULT_MODEL=gpt-5.2

# ============================================================
# LiteLLM Proxy (optional — for centralized model routing)
# ============================================================
LITELLM_PROXY_API_KEY=sk-1234
LITELLM_PROXY_API_BASE=http://litellm.overcastlab.com:4000

# ============================================================
# Server
# ============================================================
PORT=8080
